# Copy to .env and adjust. No passwords are ever stored here — login is interactive.

# Base URL of the SOIC / Learnyst learning portal
SOIC_BASE_URL=https://learn.soic.in

# Path the portal lands on after a successful login (used to detect "logged in").
# Adjust if your portal redirects elsewhere.
SOIC_LOGGEDIN_URL_FRAGMENT=/learn

# Polite crawl pacing (seconds). Keep these modest to avoid hammering the site.
SOIC_CRAWL_MIN_DELAY=1.5
SOIC_CRAWL_MAX_DELAY=3.5

# Comma-separated bundle slugs to crawl on the Learnyst portal. The SOIC
# Membership bundle is "SOIC-Course" (URL: /learn/home/SOIC-Course).
SOIC_BUNDLE_SLUGS=SOIC-Course

# Pipe-separated watermark lines to strip from captured AI summaries — set these
# to the identity the portal overlays on content (your login email / phone), e.g.
# SOIC_WATERMARK_LINES=you@example.com|+910000000000

# Run the crawler with a visible browser window (true) or headless (false).
SOIC_CRAWL_HEADED=false

# Where to write the Obsidian notes. Point this at a folder inside your real
# Obsidian vault so the notes appear in Obsidian automatically. Leave unset to
# use a local ./vault folder in the repo. Example:
# SOIC_VAULT_DIR=~/Documents/Obsidian/MyVault/SOIC

# --- Cloud vault sync (git-backed Obsidian vault) ---
# The cloud Claude Code container CANNOT reach iCloud Drive (no Linux client, no
# public API), so mirror the vault into a SEPARATE PRIVATE git repo. On the Mac/
# iOS the Obsidian Git plugin auto-commits+pushes it alongside iCloud; in the
# cloud, `scripts/vault_sync.py` clones/pulls it and exposes it as the vault dir.
# See docs/CLOUD_VAULT_SYNC.md. Only these VAULT_* vars are used by that script.
#
# Clone URL of your private vault repo (required to use vault_sync.py):
# VAULT_GIT_REMOTE=https://github.com/<you>/obsidian-vault.git
# Where to clone inside the container (default ~/obsidian-vault):
# VAULT_LOCAL_DIR=~/obsidian-vault
# Folder INSIDE the repo that is the media vault. Set this if you mirrored the
# whole iCloud container (whose media vault is the "Obsidian Vault" subfolder);
# leave unset if the repo root itself is the vault.
# VAULT_SUBDIR=Obsidian Vault
# Branch to track (default main):
# VAULT_GIT_BRANCH=main
# Optional PAT for an https remote. Leave UNSET if the vault repo is already in
# this session's GitHub scope (add it via add_repo / the Claude GitHub settings).
# VAULT_GIT_TOKEN=

# --- Substack toolkit ---
# Dedicated Obsidian vault for Substack channels.
SUBSTACK_VAULT_DIR="~/Documents/Obsidian Vault/Substack"
# Politeness delays between API requests (seconds).
SUBSTACK_CRAWL_MIN_DELAY=1.5
SUBSTACK_CRAWL_MAX_DELAY=3.5
# Show the browser during `substack-toolkit login`.
SUBSTACK_CRAWL_HEADED=true
