# Copy to .env and adjust. No passwords are ever stored here — login is interactive.

# Base URL of the SOIC / Learnyst learning portal
SOIC_BASE_URL=https://learn.soic.in

# Path the portal lands on after a successful login (used to detect "logged in").
# Adjust if your portal redirects elsewhere.
SOIC_LOGGEDIN_URL_FRAGMENT=/learn

# Polite crawl pacing (seconds). Keep these modest to avoid hammering the site.
SOIC_CRAWL_MIN_DELAY=1.5
SOIC_CRAWL_MAX_DELAY=3.5

# Run the crawler with a visible browser window (true) or headless (false).
SOIC_CRAWL_HEADED=false
